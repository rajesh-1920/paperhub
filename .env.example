# Copy to .env to configure the backend.
# Leave MONGODB_URI unset to use the JSON-file store (no database needed).

# Use MongoDB (e.g. the Docker container from `npm run db:up`):
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=paperhub

# HTTP port for the server.
PORT=7000

# --- Authentication ---------------------------------------------------------
# Secrets used to sign access/refresh tokens. MUST be set to long random values
# in production (the server refuses to boot with NODE_ENV=production and a weak
# JWT_SECRET). Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
REFRESH_SECRET=change-me-to-a-different-long-random-secret

# Token lifetimes. Defaults are long ("3650d") so a user stays signed in until
# they log out; shorten these (e.g. ACCESS_TTL=15m) for a hardened deployment.
ACCESS_TTL=3650d
REFRESH_TTL=3650d

# bcrypt cost factor for password hashing (10-12 is typical).
BCRYPT_ROUNDS=12

# --- Sign in with Google (optional) -----------------------------------------
# The app ships a built-in web client id, so the Google button works out of the
# box — leave this line commented to use it. To use your OWN OAuth 2.0 Web client
# id (Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID ->
# Web application; add your origin to "Authorized JavaScript origins"), uncomment
# and set it below. Setting it to an EMPTY value hides the Google button.
# The client id is public; no client secret is needed.
# GOOGLE_CLIENT_ID=
