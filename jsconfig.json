{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["public/assets/js/**/*.js", "tests/**/*.mjs", "eslint.config.js"],
  "exclude": ["node_modules", "public/assets/css"]
}
