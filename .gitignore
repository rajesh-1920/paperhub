# ───────────────────────────── Dependencies ─────────────────────────────
node_modules/
.npm/
.pnp
.pnp.js

# ───────────────────────────── Logs & debug ─────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────── Environment / secrets ────────────────────
# Never commit local secrets. Commit a `.env.example` template instead.
.env
.env.*
!.env.example

# ───────────────────────────── Caches & temp ────────────────────────────
.cache/
.parcel-cache/
.temp/
tmp/
*.tmp
*.bak

# ───────────────────────────── Uploaded files ───────────────────────────
# Uploaded PDF binaries (JSON-store backend); MongoDB uses GridFS instead.
server/uploads/

# ───────────────────────────── Test / coverage ──────────────────────────
coverage/
.nyc_output/

# NOTE: public/assets/css/tailwind.css is the built Tailwind output and is
# committed intentionally — the app is served statically with no build step,
# so the compiled CSS must ship in the repo. Do not ignore it.

# ───────────────────────────── Editors & IDEs ───────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ───────────────────────────── AI assistants / agents ───────────────────
# Local AI/agent tool config, rules, and chat history — never commit these.
.claude/
CLAUDE.md
CLAUDE.local.md
.cursor/
.cursorrules
.cursorignore
.aider*
.windsurf/
.windsurfrules
.continue/
.codeium/
.github/copilot-instructions.md
.mcp.json
AGENTS.md
GEMINI.md
.gemini/

# ───────────────────────────── OS files ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Runtime JSON database (seeded from server/seed.json on first boot — never
# commit it; it holds mutable state + credentials and must not be a static asset)
public/assets/data/paperhub-backend.json

# ───────────────────────────── Mobile / Android build ───────────────────
# Built APKs, signing keystores, and intermediate build output (commit the
# mobile/ source, not the binaries).
*.apk
*.keystore
*.jks
mobile/out/
